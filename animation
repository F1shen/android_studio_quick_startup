
import android.view.View
import android.view.animation.DecelerateInterpolator
import android.view.animation.OvershootInterpolator

/**
 * 實用的組合動畫：優雅地彈出顯示
 * 包含：透明度 + 向上位移 + 縮放彈跳
 */
fun View.animateEntrance() {
    // 1. 初始化狀態 (準備動作)
    this.alpha = 0f                 // 完全透明
    this.translationY = 100f        // 往下位移 100 像素
    this.scaleX = 0.8f              // 縮小到 80%
    this.scaleY = 0.8f
    this.visibility = View.VISIBLE  // 確保 View 是可見的

    // 2. 開始組合動畫
    this.animate()
        .alpha(1f)                  // 變透明為不透明
        .translationY(0f)           // 回到原始位置
        .scaleX(1f)                 // 恢復原始大小
        .scaleY(1f)
        .setDuration(500)           // 動畫時長 0.5 秒
        // 使用 OvershootInterpolator 會產生「稍微超過再彈回」的動感效果
        .setInterpolator(OvershootInterpolator(1.2f)) 
        .withStartAction {
            // 動畫開始前可以做的事情 (例如禁用按鈕防止重複點擊)
            this.isEnabled = false
        }
        .withEndAction {
            // 動畫結束後的動作
            this.isEnabled = true
        }
        .start()
}

/**
 * 實用的組合動畫：點擊縮放反饋 (微互動)
 */
fun View.animateClickEffect() {
    // 先縮小再放大回原位，模擬物理按壓感
    this.animate()
        .scaleX(0.9f)
        .scaleY(0.9f)
        .setDuration(100)
        .withEndAction {
            this.animate()
                .scaleX(1f)
                .scaleY(1f)
                .setDuration(100)
                .start()
        }
        .start()
}

