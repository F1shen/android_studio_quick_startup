package com.example.test1

import android.os.Bundle
import android.text.Editable
import android.text.TextWatcher
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.EditText
import android.widget.TextView
import androidx.appcompat.app.AppCompatActivity
import androidx.recyclerview.widget.LinearLayoutManager
import androidx.recyclerview.widget.RecyclerView
import com.google.gson.Gson
import com.google.gson.reflect.TypeToken
import okhttp3.*
import java.io.IOException

// --- 數據模型 ---
// --- 主程式 ---
class MainActivity : AppCompatActivity() {

    private lateinit var recyclerView: RecyclerView
    private lateinit var etSearch: EditText
    private lateinit var userAdapter: UserAdapter

    // 用於存放從 API 獲取的原始完整列表
    private var fullUserList: List<User> = listOf()

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        setContentView(R.layout.activity_main)

        recyclerView = findViewById(R.id.recyclerView)
        etSearch = findViewById(R.id.etSearch)

        // 設置橫向佈局 (HORIZONTAL)
        recyclerView.layoutManager = LinearLayoutManager(this, LinearLayoutManager.HORIZONTAL, false)

        // 初始化 Adapter 並綁定
        userAdapter = UserAdapter(mutableListOf())
        recyclerView.adapter = userAdapter

        // 加入搜尋監聽
        etSearch.addTextChangedListener(object : TextWatcher {
            override fun beforeTextChanged(s: CharSequence?, start: Int, count: Int, after: Int) {}
            override fun onTextChanged(s: CharSequence?, start: Int, before: Int, count: Int) {
                // 執行過濾邏輯
                filterList(s.toString())
            }
            override fun afterTextChanged(s: Editable?) {}
        })

        fetchUserData()
    }

    private fun fetchUserData() {
        val client = OkHttpClient()
        val request = Request.Builder()
            .url("https://jsonplaceholder.org/users")
            .build()

        client.newCall(request).enqueue(object : Callback {
            override fun onFailure(call: Call, e: IOException) {
                e.printStackTrace()
            }

            override fun onResponse(call: Call, response: Response) {
                val jsonString = response.body?.string()
                if (jsonString != null) {
                    val userType = object : TypeToken<List<User>>() {}.type
                    // 將結果存入原始列表
                    fullUserList = Gson().fromJson(jsonString, userType)

                    runOnUiThread {
                        // 初始化顯示所有用戶
                        userAdapter.updateData(fullUserList)
                    }
                }
            }
        })
    }

    // 搜尋過濾邏輯
    private fun filterList(query: String) {
        val filteredList = fullUserList.filter {
            it.firstname.contains(query, ignoreCase = true) ||
                    it.lastname.contains(query, ignoreCase = true)
        }
        userAdapter.updateData(filteredList)
    }
}


