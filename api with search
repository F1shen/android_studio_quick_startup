//UserAdopter

package com.example.test1

import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import androidx.recyclerview.widget.RecyclerView

// 統一建構子參數名稱為 displayList
class UserAdapter(private var displayList: List<User>) :
    RecyclerView.Adapter<UserAdapter.UserViewHolder>() {

    class UserViewHolder(view: View) : RecyclerView.ViewHolder(view) {
        val tvName: TextView = view.findViewById(R.id.tvName)
        val tvEmail: TextView = view.findViewById(R.id.tvEmail)
        val tvCompany: TextView = view.findViewById(R.id.tvCompany)
    }

    // --- 這裡整合為一個更新方法即可 ---
    // 無論是第一次拿數據還是搜尋過濾，都呼叫這個方法
    fun updateData(newList: List<User>) {
        this.displayList = newList
        notifyDataSetChanged() // 通知數據已改變，刷新畫面
    }

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): UserViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_user_card, parent, false)
        return UserViewHolder(view)
    }

    override fun onBindViewHolder(holder: UserViewHolder, position: Int) {
        val user = displayList[position]
        holder.tvName.text = "${user.firstname} ${user.lastname}"
        holder.tvEmail.text = user.email
        holder.tvCompany.text = "🏢 ${user.company.name}"
    }

    override fun getItemCount() = displayList.size
}


